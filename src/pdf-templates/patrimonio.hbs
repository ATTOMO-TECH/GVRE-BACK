<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      @font-face {
        font-family: 'teodor';
        src: url('{{{teodorLight}}}') format('woff2');
        font-weight: 300;
        font-style: normal;
      }

      @font-face {
        font-family: 'teodor';
        src: url('{{{teodorRegular}}}') format('woff2');
        font-weight: 400;
        font-style: normal;
      }

      :root {
        --text: #2b363d;
        --bg-pill: #e4e4e4;
        --border: #e4e4e4;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: "Jost", "Jost Fallback", sans-serif;
        color: var(--text);
        background-color: #f8f7f7;
        -webkit-print-color-adjust: exact;
      }
      @page {
        size: A4;
        margin: 0;
      }
      .container {
        width: 210mm;
        height: 297mm;
        padding: 20px;
        position: relative;
        display: flex;
        flex-direction: column;
      }

      .header {
        text-align: center;
        margin-bottom: 15px;
      }
      .logo-main {
        width: 40px;
        margin-bottom: 8px;
      }
      .location-tag {
        font-size: 9px;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .property-title {
        font-family: "teodor", "teodor Fallback", serif;
        font-size: 22px;
        font-weight: 300; /* Teodor Light */
        margin-bottom: 8px;
      }

      /* --- NUEVOS ESTILOS DE PRECIOS (Diseño Figma) --- */
      .prices-row {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 25px;
        margin-bottom: 12px;
      }
      .price-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
      }
      .price-text-group {
        display: flex;
        flex-direction: column;
        align-items: flex-end; /* Alineado a la derecha */
        gap: 1px;
      }
      .price-val {
        font-size: 18px;
        font-weight: 500;
        line-height: 1;
      }
      .price-val2 {
        font-size: 8px;
        font-weight: 400;
        text-transform: uppercase;
        color: var(--text);
        letter-spacing: 0.5px;
      }
      .label-pill {
        background: var(--bg-pill);
        font-size: 8px;
        padding: 3px 10px;
        border-radius: 50px;
      }
      .profitability-pill {
        background: #2b363d;
        color: white;
      }
      /* ------------------------------------------------ */

      .specs-header {
        display: flex;
        justify-content: center;
        gap: 20px;
        font-size: 9px;
        text-transform: uppercase;
      }
      .specs-header span {
        display: flex;
        align-items: center;
        gap: 5px;
      }

      .hero-container {
        position: relative;
        width: 100%;
        height: 350px;
        margin-bottom: 15px;
        border-radius: 8px;
        overflow: hidden;
      }
      .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        margin: 20px 0;
      }
      h2 {
        font-family: "teodor", "teodor Fallback", serif;
        font-size: 20px;
        font-weight: 400; /* Teodor Regular */
        margin-bottom: 10px;
      }
      .divider {
        border: none;
        border-top: 0.2px solid var(--border);
        height: 0;
        width: 100%;
        display: block;
        margin: 10px 0;
      }

      .section-description {
        font-size: 10px;
        line-height: 1.7;
        text-align: justify;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 7;
        overflow: hidden;
      }

      /* --- ESTILOS DE LA TABLA DE SUPERFICIES --- */
      .surfaces-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 9px;
        margin-bottom: 15px;
        color: var(--text);
        border: 0.5px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
      }
      .surfaces-table th {
        background-color: #e0e0e0;
        font-weight: 400;
        text-align: left;
        padding: 6px 10px;
        color: var(--text);
      }
      .surfaces-table td {
        padding: 6px 10px;
        border-bottom: 0.5px solid #e0e0e0;
        background-color: #f8f7f7;
      }
      .surfaces-table tr:last-child td {
        border-bottom: none;
      }

      /* --- ESTILOS DETALLES TABULARES --- */
      .details-list {
        margin-top: 15px;
      }
      .detail-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin: 10px 0;
      }
      .detail-row {
        display: flex;
        justify-content: space-between;
        font-size: 9px;
        text-transform: uppercase;
        color: var(--text);
      }
      .detail-row span:last-child {
        font-weight: 500;
        text-align: right;
      }

      /* --- ESTILOS ICONOS DETALLES --- */
      .details-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 20px;
      }
      .detail-item {
        font-size: 10px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .icon-svg {
        width: 14px;
        height: 14px;
      }

      .attributes-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .attr-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 10px;
        text-transform: uppercase;
      }

      /* --- FOOTER --- */
      .footer {
        position: absolute;
        bottom: 20px;
        left: 20px;
        right: 20px;
        padding-top: 25px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .agent-info {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .agent-img {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
      }
      .agent-data {
        display: flex;
        flex-direction: column;
        gap: 2px;
        font-size: 10px;
      }
      .agent-phone-and-ubication {
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .footer-logo {
        width: 35px;
      }
      .qr-wrapper {
        flex: 1;
        display: flex;
        justify-content: flex-end;
      }
      .qr-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
      }
      .property-link {
        font-size: 7px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text);
        text-decoration: none;
        border-bottom: 0.5px solid var(--border);
        padding-bottom: 1px;
        font-family: "Jost", sans-serif;
        opacity: 0.7;
      }
      .qr-code {
        width: 60px;
        height: 60px;
      }

      .legal-footer {
        position: absolute;
        bottom: 8px;
        width: 100%;
        left: 0;
        text-align: center;
        font-size: 7px;
        opacity: 0.8;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header class="header">
        <img src="{{frontendUrl}}/gvre-logo.svg" class="logo-main" />
        <div class="location-tag">{{city}}</div>
        <h1 class="property-title">{{title}}</h1>

        <div class="prices-row">
          {{#each prices}}
            <div class="price-item">
              <span class="label-pill">{{label}}</span>
              <div class="price-text-group">
                <span class="price-val">{{value}}</span>
                {{#if value2}}
                  <span class="price-val2">{{value2}}</span>
                {{/if}}
              </div>
            </div>
          {{/each}}
        </div>

        <div class="specs-header">
          {{#if buildSurface}}<span><img
                src="{{frontendUrl}}/icons/adQualities/Superficie.svg"
                class="icon-svg"
              />
              {{buildSurface}}
              M² CONST.</span>{{/if}}
          {{#if plotSurface}}<span><img
                src="{{frontendUrl}}/icons/adQualities/Superficie_parcela.svg"
                class="icon-svg"
              />
              {{plotSurface}}
              M² PARCELA</span>{{/if}}
          <span>REF: {{reference}}</span>
        </div>
      </header>

      <div class="hero-container">
        <img src="{{mainImage}}" class="hero-img" />
      </div>

      <div class="main-grid">
        <div class="col-left">

          <div class="section">
            <h2>Cuadro de superficies</h2>
            {{#if surfaces.length}}
              <table class="surfaces-table">
                <thead>
                  <tr>
                    <th>Planta</th>
                    <th>Uso</th>
                    <th>m²</th>
                    <th>Precio</th>
                    <th>Disponibilidad</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each surfaces}}
                    <tr>
                      <td>{{this.floor}}</td>
                      <td>{{this.use}}</td>
                      <td>{{this.meters}}</td>
                      <td>{{this.price}}</td>
                      <td>{{this.disponibility}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            {{else}}
              <div class="section-description">Información de superficies no
                disponible.</div>
            {{/if}}
          </div>

          <hr class="divider" />

          <div class="section">
            <h2>Descripción</h2>
            <div class="section-description">{{description}}</div>
          </div>

        </div>

        <div class="col-right">
          <div class="section">
            <h2>Detalles</h2>

            <div class="details-grid">
              {{#if jobPositions}}<div class="detail-item"><img
                    src="{{frontendUrl}}/icons/adQualities/Puestos_de_trabajo.svg"
                    class="icon-svg"
                  />
                  {{jobPositions}}
                  PUESTOS</div>{{/if}}
              {{#if parking}}<div class="detail-item"><img
                    src="{{frontendUrl}}/icons/adQualities/Garaje.svg"
                    class="icon-svg"
                  />
                  {{parking}}
                  GARAJE</div>{{/if}}
              {{#if bathrooms}}<div class="detail-item"><img
                    src="{{frontendUrl}}/icons/adQualities/Banho.svg"
                    class="icon-svg"
                  />
                  {{bathrooms}}
                  BAÑOS</div>{{/if}}
              {{#if subway}}<div class="detail-item"><img
                    src="{{frontendUrl}}/icons/adQualities/Metro.svg"
                    class="icon-svg"
                  />
                  METRO
                  {{subway}}</div>{{/if}}
              {{#if bus}}<div class="detail-item"><img
                    src="{{frontendUrl}}/icons/adQualities/Bus.svg"
                    class="icon-svg"
                  />
                  AUTOBÚS
                  {{bus}}</div>{{/if}}
              {{#if rooms}}<div class="detail-item"><img
                    src="{{frontendUrl}}/icons/adQualities/Habitacion.svg"
                    class="icon-svg"
                  />
                  {{rooms}}
                  HAB.</div>{{/if}}
            </div>

            <div class="details-list">
              {{#if profitabilityValue}}
                <hr class="divider" />
                <div class="detail-group">
                  <div class="detail-row"><span>Rentabilidad</span><span
                    >{{profitabilityValue}}</span></div>
                </div>
              {{/if}}

              {{#if hasFloorOrDisp}}
                <hr class="divider" />
                <div class="detail-group">
                  {{#if floor}}<div class="detail-row"><span>Planta</span><span
                      >{{floor}}</span></div>{{/if}}
                  {{#if disponibility}}<div class="detail-row"><span
                      >Disponibilidad</span><span
                      >{{disponibility}}</span></div>{{/if}}
                </div>
              {{/if}}

              {{#if hasExpenses}}
                <hr class="divider" />
                <div class="detail-group">
                  {{#if communityExpenses}}<div class="detail-row"><span>Gastos
                        de Comunidad</span><span
                      >{{communityExpenses}}</span></div>{{/if}}
                  {{#if ibi}}<div class="detail-row"><span>IBI</span><span
                      >{{ibi}}</span></div>{{/if}}
                  {{#if trashFee}}<div class="detail-row"><span>TRU</span><span
                      >{{trashFee}}</span></div>{{/if}}
                </div>
              {{/if}}
            </div>

            <hr class="divider" style="margin-top: 15px;" />

            <h2>Atributos</h2>
            <div class="attributes-grid">
              {{#each attributes}}
                <div class="attr-item">
                  <img
                    src="{{@root.frontendUrl}}/icons/adQualities/{{this.icon}}"
                    class="icon-svg"
                  />
                  {{this.label}}
                </div>
              {{/each}}
            </div>
          </div>
        </div>
      </div>

      <footer class="footer">
        <div class="agent-info">
          <img src="{{agent.photo}}" class="agent-img" />
          <div class="agent-data">
            <div style="font-weight: 500;">{{agent.name}}
              |
              {{agent.email}}</div>
            <div class="agent-phone-and-ubication">
              <img src="{{frontendUrl}}/icons/phone.svg" class="icon-svg" />
              {{agent.phone}}
            </div>
            <div class="agent-phone-and-ubication">
              <img src="{{frontendUrl}}/icons/ubication.svg" class="icon-svg" />
              {{agent.office}}
            </div>
          </div>
        </div>
        <div class="footer-logo-wrapper">
          <img src="{{frontendUrl}}/gvre-logo.svg" class="footer-logo" />
        </div>
        <div class="qr-wrapper">
          <div class="qr-container">
            <img src="{{qrCode}}" class="qr-code" />
            <a href="{{adUrl}}" class="property-link">Ver en la web</a>
          </div>
        </div>
      </footer>
      <div class="legal-footer">
        *Datos orientativos facilitados por la propiedad. Información sin
        carácter contractual.
      </div>
    </div>
  </body>
</html>