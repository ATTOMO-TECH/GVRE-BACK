<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      @font-face {
        font-family: 'teodor';
        src: url('{{{teodorLight}}}') format('woff2');
        font-weight: 300;
        font-style: normal;
      }

      @font-face {
        font-family: 'teodor';
        src: url('{{{teodorRegular}}}') format('woff2');
        font-weight: 400;
        font-style: normal;
      }

      :root {
        --text: #2b363d;
        --bg-pill: #e4e4e4;
        --border: #e4e4e4;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Jost", "Jost Fallback", sans-serif;
        color: var(--text);
        background-color: #f8f7f7;
        -webkit-print-color-adjust: exact;
      }

      @page {
        size: A4;
        margin: 0;
      }

      .container {
        width: 210mm;
        height: 297mm;
        padding: 20px;
        position: relative;
        display: flex;
        flex-direction: column;
      }

      /* --- HEADER --- */
      .header {
        text-align: center;
        margin-bottom: 15px;
      }
      .logo-main {
        width: 40px;
        margin-bottom: 8px;
      }
      .location-tag {
        font-size: 9px;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .property-title {
        font-family: "teodor", "teodor Fallback", serif;
        font-size: 22px;
        font-weight: 300;
        margin-bottom: 8px;
      }

      /* --- NUEVA ESTRUCTURA DE PRECIOS (Igual que Patrimonio) --- */
      .prices-row {
        display: flex;
        justify-content: center;
        align-items: flex-start; /* Alineación por arriba */
        gap: 25px;
        margin-bottom: 12px;
      }
      .price-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
      }
      .price-text-group {
        display: flex;
        flex-direction: column;
        align-items: flex-end; /* Alineado a la derecha */
        gap: 1px;
      }
      .price-val {
        font-size: 18px;
        font-weight: 500;
        line-height: 1;
      }
      .price-val2 {
        font-size: 8px;
        font-weight: 400;
        text-transform: uppercase;
        color: var(--text);
        letter-spacing: 0.5px;
      }
      .label-pill {
        background: var(--bg-pill);
        font-size: 8px;
        padding: 3px 10px;
        border-radius: 50px;
      }
      /* ----------------------------------------------------------- */

      .specs-header {
        display: flex;
        justify-content: center;
        gap: 20px;
        font-size: 9px;
        text-transform: uppercase;
      }
      .specs-header span {
        display: flex;
        align-items: center;
        gap: 5px;
      }

      /* --- HERO --- */
      .hero-container {
        position: relative;
        width: 100%;
        height: 350px;
        margin-bottom: 15px;
        border-radius: 8px;
        overflow: hidden;
      }
      .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* --- CONTENT --- */
      .main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        margin: 20px 0;
      }
      h2 {
        font-family: "teodor", "teodor Fallback", serif;
        font-size: 20px;
        font-weight: 400; /* Regular */
        margin-bottom: 10px;
      }

      .divider {
        border: none;
        border-top: 0.2px solid var(--border);
        height: 0;
        width: 100%;
        display: block;
        margin: 10px 0;
      }

      .section-description,
      .section-distribution {
        font-size: 10px;
        line-height: 1.7;
        text-align: justify;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 7;
        overflow: hidden;
      }

      /* --- ICONOS DETALLES --- */
      .details-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 20px;
      }
      .detail-item {
        font-size: 10px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .icon-svg {
        width: 14px;
        height: 14px;
      }

      /* --- ATRIBUTOS --- */
      .attributes-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .attr-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 10px;
        text-transform: uppercase;
      }

      /* --- FOOTER --- */
      .footer {
        position: absolute;
        bottom: 20px;
        left: 20px;
        right: 20px;
        padding-top: 25px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .agent-info {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .agent-img {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
      }
      .agent-data {
        display: flex;
        flex-direction: column;
        gap: 2px;
        font-size: 10px;
      }
      .agent-phone-and-ubication {
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .footer-logo {
        width: 35px;
      }
      .qr-wrapper {
        flex: 1;
        display: flex;
        justify-content: flex-end;
      }
      .qr-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
      }

      .property-link {
        font-size: 7px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text);
        text-decoration: none;
        border-bottom: 0.5px solid var(--border);
        padding-bottom: 1px;
        font-family: "Jost", sans-serif;
        opacity: 0.7;
        transition: opacity 0.3s;
      }
      .qr-code {
        width: 60px;
        height: 60px;
      }

      .legal-footer {
        position: absolute;
        bottom: 8px;
        width: 100%;
        left: 0;
        text-align: center;
        font-size: 7px;
        opacity: 0.8;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header class="header">
        <img src="{{frontendUrl}}/gvre-logo.svg" class="logo-main" />
        <div class="location-tag">{{city}}</div>
        <h1 class="property-title">{{title}}</h1>

        <div class="prices-row">
          {{#each prices}}
            <div class="price-item">
              <span class="label-pill">{{label}}</span>
              <div class="price-text-group">
                <span class="price-val">{{value}}</span>
                {{#if value2}}
                  <span class="price-val2">{{value2}}</span>
                {{/if}}
              </div>
            </div>
          {{/each}}
        </div>

        <div class="specs-header">
          {{#if buildSurface}}
            <span>
              <img
                src="{{frontendUrl}}/icons/adQualities/Superficie.svg"
                class="icon-svg"
              />
              {{buildSurface}}
              M² CONSTRUIDOS
            </span>
          {{/if}}

          {{#if plotSurface}}
            <span>
              <img
                src="{{frontendUrl}}/icons/adQualities/Superficie_parcela.svg"
                class="icon-svg"
              />
              {{plotSurface}}
              M² PARCELA
            </span>
          {{/if}}

          {{#if m2Terrace}}
            <span>
              <img
                src="{{frontendUrl}}/icons/adQualities/Terraza.svg"
                class="icon-svg"
              />
              {{m2Terrace}}
              M² TERRAZAS
            </span>
          {{/if}}

          <span>REF: {{reference}}</span>
        </div>
      </header>

      <div class="hero-container">
        <img src="{{mainImage}}" class="hero-img" />
      </div>

      <div class="main-grid">
        <div class="col-left">
          <div class="section">
            <h2>Descripción</h2>
            <div class="section-description">{{description}}</div>
          </div>
          <hr class="divider" />
          <div class="section">
            <h2>Distribución</h2>
            <div class="section-distribution">{{distribution}}</div>
          </div>
        </div>
        <div class="col-right">
          <div class="section">
            <h2>Detalles</h2>
            <div class="details-grid">
              {{#if rooms}}
                <div class="detail-item">
                  <img
                    src="{{frontendUrl}}/icons/adQualities/Habitacion.svg"
                    class="icon-svg"
                  />
                  {{rooms}}
                  HAB.
                </div>
              {{/if}}
              {{#if bathrooms}}
                <div class="detail-item">
                  <img
                    src="{{frontendUrl}}/icons/adQualities/Banho.svg"
                    class="icon-svg"
                  />
                  {{bathrooms}}
                  BAÑOS
                </div>
              {{/if}}
              {{#if parking}}
                <div class="detail-item">
                  <img
                    src="{{frontendUrl}}/icons/adQualities/Garaje.svg"
                    class="icon-svg"
                  />
                  {{parking}}
                  GARAJE
                </div>
              {{/if}}
              {{#if pool}}
                <div class="detail-item">
                  <img
                    src="{{frontendUrl}}/icons/adQualities/Piscina.svg"
                    class="icon-svg"
                  />
                  {{pool}}
                  PISCINA
                </div>
              {{/if}}
            </div>
            <hr class="divider" />
            <h2>Atributos</h2>
            <div class="attributes-grid">
              {{#each attributes}}
                <div class="attr-item">
                  <img
                    src="{{@root.frontendUrl}}/icons/adQualities/{{this.icon}}"
                    class="icon-svg"
                  />
                  {{this.label}}
                </div>
              {{/each}}
            </div>
          </div>
        </div>
      </div>

      <footer class="footer">
        <div class="agent-info">
          <img src="{{agent.photo}}" class="agent-img" />
          <div class="agent-data">
            <div style="font-weight: 500;">{{agent.name}}
              |
              {{agent.email}}</div>
            <div class="agent-phone-and-ubication">
              <img src="{{frontendUrl}}/icons/phone.svg" class="icon-svg" />
              {{agent.phone}}
            </div>
            <div class="agent-phone-and-ubication">
              <img src="{{frontendUrl}}/icons/ubication.svg" class="icon-svg" />
              {{agent.office}}
            </div>
          </div>
        </div>
        <div class="footer-logo-wrapper">
          <img src="{{frontendUrl}}/gvre-logo.svg" class="footer-logo" />
        </div>
        <div class="qr-wrapper">
          <div class="qr-container">
            <img src="{{qrCode}}" class="qr-code" />
            <a href="{{adUrl}}" class="property-link">Ver en la web</a>
          </div>
        </div>
      </footer>
      <div class="legal-footer">
        *Datos orientativos facilitados por la propiedad. Información sin
        carácter contractual.
      </div>
    </div>
  </body>
</html>